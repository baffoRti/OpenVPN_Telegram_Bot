# ============================================
# OpenVPN Telegram Bot Configuration
# ============================================

# --- REQUIRED SETTINGS ---
TELEGRAM_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789,987654321

# --- OpenVPN Configuration (auto-detected by default) ---
# Leave OPENVPN_SERVER_DIR empty for auto-detection:
#   - Tries /etc/openvpn/server/ first (newer installations)
#   - Falls back to /etc/openvpn/ (older installations)
# Set explicitly for non-standard installations:
# OPENVPN_SERVER_DIR=/path/to/your/openvpn

# Database for traffic statistics (required for traffic features)
OPENVPN_DB_PATH=openvpn_stats.db

# Certificate management script path
CERT_SCRIPT_PATH=/opt/openvpn-bot/manage_certs.sh

# --- OpenVPN Status & Management ---
# Status file for listing connected clients
OPENVPN_STATUS_FILE=/var/log/openvpn/status.log

# Management interface for disconnecting clients
# IMPORTANT: Add to your server.conf to enable:
#   management localhost 7505
OPENVPN_MANAGEMENT_HOST=localhost
OPENVPN_MANAGEMENT_PORT=7505

# --- Traffic Thresholds (optional) ---
# Thresholds in GB for notifications (comma-separated)
TRAFFIC_THRESHOLDS=500,700,900

# Check interval in seconds (default: 3 hours)
TRAFFIC_CHECK_INTERVAL=10800

# --- Advanced Settings (usually auto-detected) ---
# Uncomment to override auto-detected paths:

# OPENVPN_SERVER_CONF=/etc/openvpn/server/server.conf
# OPENVPN_EASYRSA_DIR=/etc/openvpn/server/easy-rsa
# OPENVPN_TLS_CRYPT_KEY=/etc/openvpn/server/tls-crypt.key
# OPENVPN_TLS_AUTH_KEY=/etc/openvpn/server/tls-auth.key
# OPENVPN_CRL_PEM=/etc/openvpn/server/crl.pem
# OPENVPN_IPP_TXT=/etc/openvpn/server/ipp.txt
# OPENVPN_CLIENT_TEMPLATE=/etc/openvpn/server/client-template.txt
# OPENVPN_CERT_DIR=/etc/openvpn/server/easy-rsa/pki

# Server IP for client .ovpn files (auto-detected if not set)
# OPENVPN_SERVER_IP=your.server.ip.address
