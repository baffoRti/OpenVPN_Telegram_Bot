# Telegram Bot Configuration
TELEGRAM_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789,987654321  # Comma-separated list of Telegram user IDs allowed to use the bot

# OpenVPN Configuration
OPENVPN_DB_PATH=openvpn_stats.db  # Path to the OpenVPN statistics SQLite database
CERT_SCRIPT_PATH=/opt/openvpn-bot/manage_certs.sh  # Path to certificate management script (absolute path on server)
OPENVPN_CERT_DIR=/etc/openvpn/easy-rsa/pki  # Directory for certificates and .ovpn config files

# OpenVPN Status File (for listing connected clients)
# openvpn-install.sh generates: status /var/log/openvpn/status.log
OPENVPN_STATUS_FILE=/var/log/openvpn/status.log  # Path to the OpenVPN status log file

# OpenVPN Management Interface (for disconnecting clients)
# IMPORTANT: openvpn-install.sh does NOT enable management interface by default.
# You must add to /etc/openvpn/server.conf:
#   management localhost 7505
# Then restart OpenVPN.
OPENVPN_MANAGEMENT_HOST=localhost  # Host where the OpenVPN management interface is listening
OPENVPN_MANAGEMENT_PORT=7505       # Port where the OpenVPN management interface is listening

# Traffic thresholds for notifications (in GB)
# The bot will notify when traffic crosses these values
# Example: TRAFFIC_THRESHOLDS=500,700,900
TRAFFIC_THRESHOLDS=500,700,900
